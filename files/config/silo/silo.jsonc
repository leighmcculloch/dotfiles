{
  "$schema": "https://raw.githubusercontent.com/leighmcculloch/silo/main/silo.schema.json",
  "backend": "container",
  "tool": "claude",
  "post_build_hooks": [
    // mpc servers
    "curl -fsSL https://deno.land/install.sh | sh"
  ],
  "mounts_ro": [
    "~/.dotfiles/files/scripts",
    "~/.zenv_apikey_pushover",
    "~/.zenv_apikey_github_ro",
    "~/.zenv_apikey_github_ro_plus_w_issues_prs"
  ],
  "mounts_rw": [],
  "env": [
    "XDG_CONFIG_HOME"
  ],
  "pre_run_hooks": [
    //"source ~/.zenv_apikey_github_ro_plus_w_issues_prs",
    "source ~/.zenv_apikey_github_ro",
    "export PATH=${HOME}/.dotfiles/files/scripts:${PATH}",
    "export PATH=${HOME}/.deno/bin:${PATH}"
  ],
  "tools": {
    "copilot": {
      "mounts_ro": [
        "~/.zenv_apikey_github_copilot"
      ],
      "pre_run_hooks": [
        "source ~/.zenv_apikey_github_copilot"
      ]
    }
  },
  "repos": {
    //"github.com/stellar": {
    //  "tool": "opencode"
    //},
    "github.com/stellar/stellar-core": {
      "post_build_hooks": [
        "sudo apt-get update",
        "sudo apt-get install -y autoconf automake libtool flex bison"
      ]
    }
  }
}

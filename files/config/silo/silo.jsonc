{
  "$schema": "https://raw.githubusercontent.com/leighmcculloch/silo/main/silo.schema.json",
  "backend": "docker",
  "backends": {
    "fly": {
      "app": "silovms",
      "region": "syd"
    }
  },
  "tool": "claude",
  "post_build_hooks": [
    "curl -fsSL https://deno.land/install.sh | sh",
    "curl -fsSL https://github.com/stellar/stellar-cli/raw/main/install.sh | sh -s -- --install-deps"
  ],
  "mounts_ro": [
    "~/.zenv_apikey_pushover",
    "~/.zenv_apikey_github_ro",
    "~/.zenv_apikey_github_ro_plus_w_issues_prs",
    "~/.dotfiles/files/scripts/gbb",
    "~/.dotfiles/files/scripts/claude-transcript",
    "~/.dotfiles/files/scripts/gemma"
  ],
  "mounts_rw": [
    "~/Code/conductor"
  ],
  "env": [
    "XDG_CONFIG_HOME"
  ],
  "pre_run_hooks": [
    "source ~/.zenv_apikey_github_ro_plus_w_issues_prs 2>/dev/null || source ~/.zenv_apikey_github_ro",
    "export PATH=${HOME}/.deno/bin:${PATH}",
    "export PATH=${HOME}/.dotfiles/files/scripts:${PATH}",
    "export GEMMA_HOST=host.docker.internal"
  ],
  "tools": {
    "copilot": {
      "mounts_ro": [
        "~/.zenv_apikey_github_copilot"
      ],
      "pre_run_hooks": [
        "source ~/.zenv_apikey_github_copilot"
      ]
    }
  },
  "repos": {
    //"github.com/stellar": {
    //  "tool": "opencode"
    //},
    "github.com/stellar/stellar-core": {
      "post_build_hooks": [
        "sudo apt-get update",
        "sudo apt-get install -y autoconf automake libtool flex bison"
      ]
    }
  }
}

    san-francisco
    san-diego
    los-angeles
    san-jose
    sacramento
    oakland
    fresno
    long-beach
    anaheim
    irvine
    santa-ana
    riverside
    stockton
    bakersfield
    las-vegas
    reno
    salt-lake-city
    denver
    colorado-springs
    albuquerque
    santa-fe
    el-paso
    austin
    san-antonio
    fort-worth
    arlington
    new-orleans
    baton-rouge
    nashville
    memphis
    birmingham
    charlotte
    raleigh
    orlando
    tampa
    jacksonville
    savannah
    richmond
    norfolk
    baltimore
    pittsburgh
    cleveland
    cincinnati
    columbus
    indianapolis
    milwaukee
    minneapolis
    kansas-city
    st-louis
    new-york
  )
  local branch="${1-}"
  local repo_name="${PWD##*/}"

  if [[ -z "$branch" ]]; then
    local candidate=""
    local -i city_count=${#cities[@]}
    local -i start=$((RANDOM % city_count + 1))
    local -i offset=0

    while (( offset < city_count )); do
      candidate="${cities[$((((start + offset - 1) % city_count) + 1))]}"
      if ! git show-ref --verify --quiet "refs/heads/$candidate" && [[ ! -e "../${repo_name}-${candidate}" ]]; then
        branch="$candidate"
        break
      fi
      ((offset++))
    done

    if [[ -z "$branch" ]]; then
      echo "gwau: no unused city names available" >&2
      return 1
    fi
  fi

  local dir="../${repo_name}-${branch}"

  git worktree prune
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$dir" "$branch"
  else
    git worktree add -b "$branch" "$dir"
  fi
} "$@"

#!/usr/bin/env zsh

set -o nounset
export SCRIPT=gbb

function {
  local branches="${${$(git branch --all --format='%(refname:short)' | jq -R -s '.')%\"}#\"}"
  local current_branch="$(git rev-parse --abbrev-ref HEAD)"
  local default_branch="$(gh repo view --json defaultBranchRef --jq .defaultBranchRef.name)"

  local on_default=0
  local commits_ahead=0
  if [[ "$current_branch" == "$default_branch" ]]; then
    on_default=1
    commits_ahead="$(git rev-list --count @{upstream}..HEAD 2>/dev/null || echo 0)"
  fi

  # On default branch with commits ahead of upstream: move commits to a new branch.
  if (( on_default && commits_ahead > 0 )); then
    local diff_source="@{upstream}..HEAD"
  elif ! git diff HEAD --quiet; then
    local diff_source="HEAD"
  else
    echo "No changes detected in working directory"
    return 1
  fi

  # Detect MDM enrollment
  local mdm_enrolled=0
  if profiles status -type enrollment 2>/dev/null | grep -q "Yes"; then
    mdm_enrolled=1
  fi

  local ai=""
  if (( mdm_enrolled )); then
    #ai="opencode run -m github-copilot/claude-opus-4.6"
    ai="claude --model claude-sonnet-4-6 --effort low -p"
  else
    ai="claude --model claude-sonnet-4-6 --effort low -p"
  fi

  local diff_cmd="git diff ${diff_source}"
  printf "○ %s\n" "$ai"
  local start_time=$(gdate +%s%6N)
  local name="$(${=ai} -p "You are a senior software engineer.

Run '${diff_cmd}' to see what has changed. Then suggest a concise, kebab-case branch name that describes the changes (max 5 words).

Reply only with the branch name, nothing else.

Do not use any of these names: ${branches}." | tr '[:upper:] ' '[:lower:]-')"
  local end_time=$(gdate +%s%6N)
  local elapsed_us=$((end_time - start_time))
  local elapsed_s=$(printf '%d.%06d' $((elapsed_us / 1000000)) $((elapsed_us % 1000000)))
  printf "\033[1A● %s (${elapsed_s}s)\033[K\n" "$ai"

  if [ -z "$name" ]; then
    echo "Error: Failed to get branch name"
    return 1
  fi

  local name="$(gum input --width 50 --char-limit 50 --prompt '| ' --value "$name")"

  if (( on_default && commits_ahead > 0 )); then
    # Create the new branch at current HEAD (includes the commits).
    git branch "$name"
    # Walk the default branch back to match upstream.
    git reset --hard @{upstream}
    # Switch to the new branch.
    git checkout "$name"
  else
    git checkout -b "$name" $@
  fi
}

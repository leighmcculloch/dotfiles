{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "bash",
      "args": [ "-c", "source ~/.zenv_apikey_github || source ~/.zenv_apikey_github_ro ; GITHUB_PERSONAL_ACCESS_TOKEN=\"$GITHUB_TOKEN\" github-mcp-server stdio" ]
    },
    "grep": {
      "type": "http",
      "url": "https://mcp.grep.app"
    }
  }
}

{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__CLAUDE_CLOUD_DIR__/hook-session-start.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__CLAUDE_CLOUD_DIR__/hook-stop.sh\""
          }
        ]
      }
    ]
  }
}

#!/bin/sh
# Reorder windows in a tmux session: non-repo windows come first, sorted
# alphabetically by path; repo windows follow, sorted alphabetically by
# repo name with windows from the same git repo (by remote origin URL)
# grouped adjacently. Preserves the active window and pane and the
# relative order of windows within each group. No-op if the windows are
# already in target order, so it's safe to invoke on every directory change.
#
# Usage: tmux-regroup-windows [session]

session="${1:-$(tmux display-message -p '#S' 2>/dev/null)}"
[ -n "$session" ] || exit 0

mapping=$(tmux list-windows -t "$session" -F '#{window_index} #{window_id} #{pane_current_path}' 2>/dev/null)
[ -n "$mapping" ] || exit 0

target_ids=$(
  echo "$mapping" | while read -r idx id path; do
    origin=$(git -C "$path" config --get remote.origin.url 2>/dev/null)
    [ -n "$origin" ] || origin="path:$path"
    printf '%s\t%s\t%s\n' "$idx" "$id" "$origin"
  done | awk '
    BEGIN { FS="\t"; OFS="\t" }
    { if ($3 ~ /^path:/)
        printf "0\t%s\t\t%010d\t%s\n", $3, $1, $2
      else {
        name = $3
        sub(/\.git$/, "", name)
        sub(/.*\//, "", name)
        printf "1\t%s\t%s\t%010d\t%s\n", name, $3, $1, $2
      } }
  ' | sort | awk -F'\t' '{print $5}'
)

current_ids=$(echo "$mapping" | awk '{print $2}')
[ "$current_ids" = "$target_ids" ] && exit 0

active_id=$(tmux display-message -p -t "$session" '#{window_id}')
base=$(tmux display-message -p -t "$session" '#{base-index}')
max_idx=$(tmux list-windows -t "$session" -F '#{window_index}' | sort -n | tail -1)
tmp_start=$((max_idx + 1))

# Two-pass move via unique temporary indices to avoid collisions. -d keeps
# the active window selection stable across each move.
i=$tmp_start
for id in $target_ids; do
  tmux move-window -d -s "$id" -t "$session:$i" 2>/dev/null
  i=$((i + 1))
done

i=$base
for id in $target_ids; do
  tmux move-window -d -s "$id" -t "$session:$i" 2>/dev/null
  i=$((i + 1))
done

tmux select-window -t "$active_id" 2>/dev/null

#!/usr/bin/env zsh

set -o nounset
export SCRIPT=gbb

function {
  local git_diff="git diff"
  if command -v rtk >/dev/null 2>&1; then
    git_diff="rtk git diff"
  fi

  local branches="${${$(git branch --all --format='%(refname:short)' | jq -R -s '.')%\"}#\"}"
  local current_branch="$(git rev-parse --abbrev-ref HEAD)"
  local default_branch="$(gh repo view --json defaultBranchRef --jq .defaultBranchRef.name)"

  local on_default=0
  local commits_ahead=0
  if [[ "$current_branch" == "$default_branch" ]]; then
    on_default=1
    commits_ahead="$(git rev-list --count @{upstream}..HEAD 2>/dev/null || echo 0)"
  fi

  local diff_source=""
  # On default branch with commits ahead of upstream: move commits to a new branch.
  if (( on_default && commits_ahead > 0 )); then
    diff_source="@{upstream}..HEAD"
  elif ! ${=git_diff} --staged --quiet; then
    diff_source="--staged"
  elif ! ${=git_diff} HEAD --quiet; then
    diff_source="HEAD"
  fi

  local diff=""
  if [[ -n "$diff_source" ]]; then
    diff="$(${=git_diff} ${diff_source})"
    local max_chars=10000
    local diff_len=${#diff}
    if (( diff_len > max_chars )); then
      diff="${diff:0:$max_chars}

[diff truncated at ${max_chars} of ${diff_len} chars]"
    fi
  fi

  local first_ask="${CLAUDE_PROMPT:-$(claude-transcript 0 2>/dev/null || true)}"
  local last_ask="${CLAUDE_PROMPT:-$(claude-transcript -1 2>/dev/null || true)}"

  if [[ -z "$diff" && -z "$first_ask" && -z "$last_ask" ]]; then
    echo "No changes detected and no transcript context available"
    return 1
  fi

  local prompt="You are a senior software engineer.

Suggest a concise, kebab-case branch name that describes the changes (max 5 words).

Reply only with the branch name, nothing else.

Do not use any of these names: ${branches}.

Original user request:
${first_ask}

Latest user request:
${last_ask}

Diff:
${diff}"

  local date_cmd="date"
  command -v gdate >/dev/null 2>&1 && date_cmd="gdate"

  local ai="gemma"
  printf "○ %s\n" "$ai"
  local start_time=$(${date_cmd} +%s%6N)
  local name="$(${=ai} "$prompt" 2>/dev/null | tr '[:upper:] ' '[:lower:]-' | awk 'NF' | head -1)"
  local end_time=$(${date_cmd} +%s%6N)
  local elapsed_us=$((end_time - start_time))
  local elapsed_s=$(printf '%d.%06d' $((elapsed_us / 1000000)) $((elapsed_us % 1000000)))
  printf "\033[1A● %s (${elapsed_s}s)\033[K\n" "$ai"

  if [ -z "$name" ]; then
    echo "Error: Failed to get branch name"
    return 1
  fi

  # Bump numeric suffix until the branch name is free.
  local candidate="$name"
  local i=2
  while git show-ref --verify --quiet "refs/heads/$candidate" && (( i <= 99 )); do
    candidate="${name}-${i}"
    ((i++))
  done
  name="$candidate"

  name="$(gum input --width 50 --char-limit 50 --prompt '| ' --value "$name")" || return $?

  local previous_upstream="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || true)"

  if (( on_default && commits_ahead > 0 )); then
    # Create the new branch at current HEAD (includes the commits).
    git branch --no-track "$name"
    # Walk the default branch back to match upstream.
    git reset --hard @{upstream}
    # Switch to the new branch.
    git checkout "$name"
  else
    git checkout -b "$name" --no-track $@
  fi

  if [[ -n "$previous_upstream" ]]; then
    git branch --set-upstream-to="$previous_upstream" "$name"
  fi
}

#!/bin/sh
# Print the color-coded short repo name for a path (hashed from the origin
# URL so same-repo windows share a color), plus the leading spacing for
# the window in the tmux status bar.
#
# Output rules:
#   - First window of a repo group:  "  <name> "  (wider gap before the
#     group, name, then a small gap to the index).
#   - Continuation of the same repo: " "          (tight intra-group gap
#     so adjacent same-repo branches feel grouped).
#   - Non-repo window:                "  "         (treated as its own
#     group, gets the wider gap).
#
# Usage: tmux-window-repo <path> [session] [index] [reset-fg]
#   <path>     the window's current directory
#   <session>  tmux session name (for previous-window lookup)
#   <index>    this window's index in the session
#   <reset-fg> tmux color to restore after the colored name (e.g. "white")

path="$1"
session="$2"
index="$3"
reset_fg="${4:-white}"
[ -n "$path" ] && [ -d "$path" ] || { printf '  '; exit 0; }

origin=$(git -C "$path" config --get remote.origin.url 2>/dev/null)
if [ -z "$origin" ]; then
  printf '  '
  exit 0
fi

if [ -n "$session" ] && [ -n "$index" ] && [ "$index" -gt 0 ]; then
  prev_index=$((index - 1))
  prev_path=$(tmux list-windows -t "$session" -F '#{window_index} #{pane_current_path}' 2>/dev/null \
    | awk -v i="$prev_index" '$1==i{ $1=""; sub(/^ /, ""); print }')
  if [ -n "$prev_path" ]; then
    prev_origin=$(git -C "$prev_path" config --get remote.origin.url 2>/dev/null)
    if [ "$prev_origin" = "$origin" ]; then
      printf ' '
      exit 0
    fi
  fi
fi

name=${origin%.git}
name=${name##*/}

printf '  #[fg=#99d5fb]%s#[fg=%s] ' "$name" "$reset_fg"
